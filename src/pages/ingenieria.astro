---
import ContactSection from '../components/ContactSection.astro';
import Navbar from '../components/Navbar.astro';
import ServicesCarousel from '../components/ServicesCarousel.astro';
import Layout from '../layouts/Layout.astro';

const highlights = [
	{
		title: 'Ingenieria y gestion de proyectos',
		description:
			'Planeamos cada solucion con base en demanda, seguridad operativa y continuidad del servicio.',
	},
	{
		title: 'Material y ejecucion coordinados',
		description:
			'Alineamos suministro, mano de obra y avance para evitar retrabajos y cuellos de botella.',
	},
	{
		title: 'Acompanamiento regulatorio',
		description:
			'Integramos tramites, verificaciones y documentacion para respaldar cada entrega.',
	},
];

const hoverCards = [
	{
		title: 'Inspeccion tecnica',
		subtitle: 'Revision puntual',
		description:
			'Revisamos cada etapa de la obra para detectar riesgos electricos y garantizar continuidad de servicio.',
		image: '/services/media-baja-tension.svg',
	},
	{
		title: 'Planeacion electrica',
		subtitle: 'Diseño y calculo',
		description:
			'Definimos rutas, protecciones y cargas con criterios de seguridad y eficiencia.',
		image: '/services/material-electrico.svg',
	},
	{
		title: 'Gestion de tramites',
		subtitle: 'Tramites CFE',
		description:
			'Acompanamos el proceso documental para que tus instalaciones avancen sin demoras.',
		image: '/services/tramites-cfe.svg',
	},
	{
		title: 'Verificacion final',
		subtitle: 'UVIES y pruebas',
		description:
			'Certificamos el cumplimiento normativo y la seguridad operativa de cada sistema electrico.',
		image: '/services/verificaciones-uvies.svg',
	},
	{
		title: 'Suministro integral',
		subtitle: 'Material de obra',
		description:
			'Proveemos componentes electricos compatibles y listos para una instalacion confiable.',
		image: '/services/material-electrico.svg',
	},
];
---

<Layout
	title="POWERLINE MULTISERVICIOS | Instalaciones electricas"
	description="Landing page de POWERLINE MULTISERVICIOS con soluciones electricas, venta de material, tramites ante CFE y verificaciones."
>
	<div class="page-shell" id="inicio">
		<Navbar />

		<main>
			<ServicesCarousel />

			<section class="highlights-section" aria-label="Propuesta de valor">
				<div class="section-copy">
					<p class="eyebrow">Por que POWERLINE</p>
					<h2>Una landing enfocada en confianza tecnica, ejecucion y cumplimiento.</h2>
				</div>

				<div class="highlight-grid">
					{highlights.map((item) => (
						<article class="highlight-card">
							<div class="highlight-index" aria-hidden="true"></div>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="hover-effect-section" aria-label="Hover effect">
				<div class="section-copy">
					<p class="eyebrow">Hover effect</p>
					<h2>Tarjetas interactivas con imagen de fondo y texto emergente.</h2>
					<p>Coloca el puntero sobre cada cuadro para ver el fondo suavizarse y el texto aparecer con claridad.</p>
				</div>

				<div class="hover-grid">
					{hoverCards.map((card) => (
						<article class="hover-card" tabindex="0" style={`--card-image: url('${card.image}');`}>
							<div class="hover-card-content">
								<span>{card.subtitle}</span>
								<h3>{card.title}</h3>
								<p>{card.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="stats-section" aria-label="Resumen corporativo">
				<div class="stats-copy">
					<p class="eyebrow">Cobertura integral</p>
					<h2>Desde la planeacion hasta la verificacion final.</h2>
					<p>
						Integramos servicios que ayudan a resolver necesidades electricas con una sola
						linea de trabajo: diagnostico, suministro, gestion y ejecucion.
					</p>
				</div>

				<div class="stats-grid">
					<div class="stat-card">
						<strong>4</strong>
						<span>lineas de servicio prioritarias</span>
					</div>
					<div class="stat-card">
						<strong>CFE</strong>
						<span>acompanamiento en tramites y gestion</span>
					</div>
					<div class="stat-card">
						<strong>UVIES</strong>
						<span>verificacion enfocada en seguridad y cumplimiento</span>
					</div>
				</div>
			</section>

			<ContactSection />
		</main>
	</div>
</Layout>

<style>
	.page-shell {
		padding: 0;
	}

	main {
		display: grid;
		gap: 0;
	}

	.highlights-section,
	.stats-section {
		width: var(--content-width);
		margin: 0 auto;
	}

	.highlights-section {
		padding: 0.5rem 0 3.5rem;
	}

	.section-copy {
		display: grid;
		gap: 0.8rem;
		max-width: 44rem;
		margin-bottom: 1.6rem;
	}

	.eyebrow {
		margin: 0;
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2,
	h3,
	p {
		margin: 0;
	}

	h2 {
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.08;
	}

	p {
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	.highlight-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.highlight-card,
	.stat-card {
		padding: 1.6rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
			var(--color-surface-elevated);
	}

	.highlight-card {
		display: grid;
		gap: 0.9rem;
	}

	.highlight-index {
		width: 3rem;
		height: 0.35rem;
		border-radius: 999px;
		background: var(--color-primary);
	}

	.highlight-card h3 {
		font-size: 1.12rem;
		line-height: 1.35;
	}

	.hover-effect-section {
		width: var(--content-width);
		margin: 0 auto;
		padding: 2rem 0 3rem;
	}

	.hover-effect-section .section-copy {
		margin-bottom: 1.6rem;
	}

	.hover-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
	}

	.hover-card {
		position: relative;
		min-height: 24rem;
		border-radius: 1.75rem;
		overflow: hidden;
		padding: 1.75rem;
		background: var(--card-image) center/cover no-repeat;
		box-shadow: 0 18px 40px rgba(0, 0, 0, 0.2);
		transition: transform 0.35s ease, box-shadow 0.35s ease;
		cursor: pointer;
	}

	.hover-card::before,
	.hover-card::after {
		content: '';
		position: absolute;
		inset: 0;
		transition: opacity 0.35s ease, filter 0.35s ease;
	}

	.hover-card::before {
		background: linear-gradient(180deg, rgba(10, 10, 10, 0.12), rgba(8, 8, 8, 0.88));
		opacity: 1;
		z-index: 0;
	}

	.hover-card::after {
		background: inherit;
		background-position: center;
		background-size: cover;
		filter: blur(var(--hover-blur, 8px));
		opacity: 0;
		z-index: 0;
	}

	.hover-card:hover,
	.hover-card:focus-visible {
		transform: translateY(-5px);
		box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
	}

	.hover-card:hover::after,
	.hover-card:focus-visible::after {
		opacity: 0.55;
	}

	.hover-card:hover::before,
	.hover-card:focus-visible::before {
		opacity: 0.45;
	}

	.hover-card-content {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 0.65rem;
		color: #fff;
		opacity: 0;
		transform: translateY(1rem);
		transition: opacity 0.35s ease, transform 0.35s ease;
	}

	.hover-card:hover .hover-card-content,
	.hover-card:focus-visible .hover-card-content {
		opacity: 1;
		transform: translateY(0);
	}

	.hover-card span {
		display: inline-flex;
		padding: 0.45rem 0.9rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.14);
		border: 1px solid rgba(255, 255, 255, 0.22);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #fff;
		width: fit-content;
	}

	.hover-card h3 {
		font-size: 1.25rem;
		line-height: 1.35;
	}

	.hover-card p {
		color: rgba(255, 255, 255, 0.92);
		line-height: 1.7;
	}

	.stats-section {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
		gap: 1.25rem;
		padding: 0 0 1.5rem;
		align-items: start;
	}

	.stats-copy {
		display: grid;
		gap: 1rem;
		padding-top: 0.3rem;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.stat-card {
		display: grid;
		align-content: start;
		gap: 0.85rem;
		min-height: 12rem;
	}

	.stat-card strong {
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1;
		color: var(--color-primary);
	}

	.stat-card span {
		color: var(--color-text-muted);
		line-height: 1.6;
	}

	@media (max-width: 960px) {
		.highlight-grid,
		.stats-grid,
		.stats-section,
		.hover-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
