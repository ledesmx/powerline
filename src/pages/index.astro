---
import ClientsSection from '../components/ClientsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import PropValorSection from '../components/PropValorSection.astro';
import ServicesCarousel from '../components/ServicesCarousel.astro';
import ValorSection from '../components/ValorSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Powerline Multiservicios | Instalaciones Electricas en Parral"
	description="POWERLINE MULTISERVICIOS instalaciones y soluciones electricas, venta de material, tramites ante CFE y verificaciones."
>
	<div class="page-shell" id="inicio">
		<Navbar />

		<main>
			<ServicesCarousel />

			<PropValorSection />

			<ValorSection />

			<ServicesSection />

			<ClientsSection />

			<ProjectsSection />

			<ContactSection />
		</main>
		<Footer />
	</div>
</Layout>

<style>
	.page-shell {
		padding: 0;
	}

	main {
		display: grid;
		gap: 0;
	}

	.eyebrow {
		margin: 0;
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h2,
	h3,
	p {
		margin: 0;
	}

	h2 {
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.08;
	}

	p {
		color: var(--color-text-muted);
		line-height: 1.75;
	}

	@media (max-width: 960px) {
</style>
