---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'POWERLINE MULTISERVICIOS | Instalaciones electricas',
	description = 'Instalaciones electricas, suministro de material, tramites ante CFE y verificaciones para proyectos de media y baja tension.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f3582c" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		--color-primary: #f3582c;
		--color-primary-soft: rgba(243, 88, 44, 0.14);
		--color-surface: #050505;
		--color-surface-elevated: #101010;
		--color-surface-muted: #161616;
		--color-border: rgba(255, 255, 255, 0.08);
		--color-text: #ffffff;
		--color-text-muted: rgba(255, 255, 255, 0.72);
		--shadow-soft: 0 24px 80px rgba(0, 0, 0, 0.36);
		--content-width: min(1120px, calc(100% - 2rem));
	}

	html {
		scroll-behavior: smooth;
		background: var(--color-surface);
	}

	body {
		margin: 0;
		min-width: 320px;
		min-height: 100vh;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
		background:
			radial-gradient(circle at top right, rgba(243, 88, 44, 0.28), transparent 30%),
			linear-gradient(180deg, #090909 0%, #050505 100%);
		color: var(--color-text);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	::selection {
		background: rgba(243, 88, 44, 0.34);
		color: #fff;
	}
</style>
