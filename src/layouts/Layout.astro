---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'POWERLINE MULTISERVICIOS | Instalaciones electricas',
	description = 'Instalaciones electricas, suministro de material, tramites ante CFE y verificaciones para proyectos de media y baja tension.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cabin:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f3582c" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--color-primary: #f3582c;
		--color-primary-soft: rgba(243, 88, 44, 0.1);
		--color-surface: #ffffff;
		--color-surface-elevated: #f5f6f7;
		--color-surface-muted: #eceef0;
		--color-border: rgba(23, 26, 32, 0.1);
		--color-text: #171a20;
		--color-text-muted: rgba(23, 26, 32, 0.58);
		--shadow-soft: 0 4px 24px rgba(0, 0, 0, 0.08);
		--content-width: calc(100% - clamp(2rem, 8vw, 6rem));
	}

	html {
		scroll-behavior: smooth;
		background: var(--color-surface);
	}

	body {
		margin: 0;
		min-width: 320px;
		min-height: 100vh;
		font-family:
			'Cabin', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI',
			sans-serif;
		background:
			radial-gradient(circle at top right, rgba(243, 88, 44, 0.07), transparent 35%),
			#ffffff;
		color: var(--color-text);
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	::selection {
		background: rgba(243, 88, 44, 0.34);
		color: #fff;
	}
</style>
