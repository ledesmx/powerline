---
const services = [
	{
		tag: 'Media y baja tension',
		title: 'Planeacion estrategica y ejecucion experta en media y baja tension',
		description:
			'Desarrollamos soluciones electricas para proyectos residenciales, comerciales e industriales con enfoque en seguridad, capacidad operativa y continuidad del servicio.',
		image: '/services/media-baja-tension.svg',
	},
	{
		tag: 'Suministro electrico',
		title: 'Venta de material electrico',
		description:
			'Suministramos componentes y material electrico para obra nueva, mantenimiento y ampliaciones, cuidando compatibilidad, disponibilidad y rendimiento.',
		image: '/services/material-electrico.svg',
	},
	{
		tag: 'Gestion regulatoria',
		title: 'Gestion de tramites ante la CFE',
		description:
			'Acompanamos el proceso documental y tecnico para que tus instalaciones avancen con orden, claridad y seguimiento en cada etapa del tramite.',
		image: '/services/tramites-cfe.svg',
	},
	{
		tag: 'Cumplimiento y verificacion',
		title: 'Verificaciones y UVIES de instalaciones',
		description:
			'Realizamos verificaciones para respaldar la seguridad y cumplimiento de tus instalaciones con una vision tecnica y preventiva.',
		image: '/services/verificaciones-uvies.svg',
	},
];
---

<section class="services-hero" id="servicios">
	<div class="copy-column">
		<p class="eyebrow">Soluciones electricas integrales</p>
		<h1>Energia confiable para proyectos que necesitan precision, cumplimiento y respuesta.</h1>
		<p class="lead">
			POWERLINE MULTISERVICIOS integra planeacion, suministro, tramites y verificacion para
			resolver instalaciones electricas con una ejecucion clara y profesional.
		</p>
		<div class="actions">
			<a class="primary-action" href="#contacto">Solicitar asesoria</a>
			<a class="secondary-action" href="#servicios-lista">Explorar servicios</a>
		</div>
	</div>

	<div class="carousel-column">
		<div class="carousel" aria-label="Carrusel automatico de servicios" aria-live="off">
			{services.map((service, index) => (
				<article class="slide" style={`--delay: -${index * 8}s;`}>
					<img
						src={service.image}
						alt=""
						width="800"
						height="520"
						loading={index === 0 ? 'eager' : 'lazy'}
					/>
					<div class="slide-content">
						<span>{service.tag}</span>
						<h2>{service.title}</h2>
						<p>{service.description}</p>
					</div>
				</article>
			))}
		</div>

		<ul class="indicators" aria-label="Servicios destacados">
			{services.map((service) => (
				<li>{service.tag}</li>
			))}
		</ul>
	</div>
</section>

<section class="service-list" id="servicios-lista">
	<div class="section-heading">
		<p class="eyebrow">Cobertura comercial y tecnica</p>
		<h2>Servicios que acompañan la instalacion de principio a fin.</h2>
	</div>

	<div class="service-grid">
		{services.map((service) => (
			<article class="service-card">
				<span>{service.tag}</span>
				<h3>{service.title}</h3>
				<p>{service.description}</p>
			</article>
		))}
	</div>
</section>

<style>
	.services-hero,
	.service-list {
		width: var(--content-width);
		margin: 0 auto;
	}

	.services-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		gap: 2rem;
		padding: 4rem 0 3rem;
		align-items: center;
	}

	.copy-column {
		display: grid;
		gap: 1.25rem;
	}

	.eyebrow {
		margin: 0;
		color: var(--color-primary);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	h1 {
		font-size: clamp(2.75rem, 5vw, 4.5rem);
		line-height: 0.98;
		max-width: 12ch;
	}

	.lead {
		max-width: 60ch;
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1.75;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.primary-action,
	.secondary-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 1.35rem;
		border-radius: 4px;
		font-weight: 700;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.primary-action {
		background: var(--color-primary);
		color: #fff;
		box-shadow: 0 18px 40px rgba(243, 88, 44, 0.28);
	}

	.secondary-action {
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: var(--color-text);
	}

	.primary-action:hover,
	.secondary-action:hover,
	.primary-action:focus-visible,
	.secondary-action:focus-visible {
		transform: translateY(-2px);
		outline: none;
	}

	.secondary-action:hover,
	.secondary-action:focus-visible {
		border-color: rgba(243, 88, 44, 0.4);
		background: rgba(255, 255, 255, 0.03);
	}

	.carousel-column {
		display: grid;
		gap: 1rem;
	}

	.carousel {
		position: relative;
		min-height: 520px;
		border-radius: 2rem;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: #0b0b0b;
		box-shadow: var(--shadow-soft);
	}

	.slide {
		position: absolute;
		inset: 0;
		display: grid;
		opacity: 0;
		animation: fade-carousel 32s infinite ease-in-out;
		animation-delay: var(--delay);
	}

	.slide img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.slide::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.06), rgba(0, 0, 0, 0.7)),
			linear-gradient(110deg, rgba(5, 5, 5, 0.78) 18%, rgba(5, 5, 5, 0.1) 70%);
	}

	.slide-content {
		position: absolute;
		left: 2rem;
		right: 2rem;
		bottom: 2rem;
		z-index: 1;
		display: grid;
		gap: 0.7rem;
		max-width: 32rem;
	}

	.slide-content span {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.45rem 0.8rem;
		border-radius: 999px;
		background: rgba(243, 88, 44, 0.16);
		border: 1px solid rgba(243, 88, 44, 0.35);
		color: #fff;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.slide-content h2 {
		font-size: clamp(1.55rem, 2vw, 2.25rem);
		line-height: 1.1;
	}

	.slide-content p {
		color: rgba(255, 255, 255, 0.82);
		line-height: 1.7;
	}

	.indicators {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.75rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.indicators li {
		padding: 0.9rem 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.03);
		color: var(--color-text-muted);
		font-size: 0.86rem;
		line-height: 1.4;
	}

	.service-list {
		padding: 1rem 0 4rem;
	}

	.section-heading {
		display: grid;
		gap: 0.75rem;
		max-width: 42rem;
		margin-bottom: 1.8rem;
	}

	.section-heading h2 {
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 1.05;
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.service-card {
		display: grid;
		gap: 0.9rem;
		padding: 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 1.5rem;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)),
			var(--color-surface-elevated);
	}

	.service-card span {
		color: var(--color-primary);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.service-card h3 {
		font-size: 1.15rem;
		line-height: 1.35;
	}

	.service-card p {
		color: var(--color-text-muted);
		line-height: 1.7;
	}

	@keyframes fade-carousel {
		0%,
		18% {
			opacity: 1;
			transform: scale(1);
		}

		23%,
		100% {
			opacity: 0;
			transform: scale(1.03);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.slide {
			animation: none;
			opacity: 0;
		}

		.slide:first-child {
			opacity: 1;
			position: relative;
		}
	}

	@media (max-width: 960px) {
		.services-hero {
			grid-template-columns: 1fr;
			padding-top: 3rem;
		}

		h1 {
			max-width: 14ch;
		}

		.indicators,
		.service-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.carousel {
			min-height: 440px;
		}

		.slide-content {
			left: 1.35rem;
			right: 1.35rem;
			bottom: 1.35rem;
		}

		.slide-content h2 {
			font-size: 1.45rem;
		}

		.indicators,
		.service-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
