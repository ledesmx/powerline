---
---

<section class="hero-carousel" id="servicios" aria-label="Servicios POWERLINE">
	<img
		src="/hero/bg2.png"
		alt=""
		loading="eager"
	/>
	<div class="slide-content">
		<h1 class="slide-title">
			<span class="title-headline">Expertos en Instalaciones Electricas de Parral y sus alrededores</span>
			<span class="title-tagline">Resolvemos cualquiera de tus problemas para energizar proyectos industriales y residenciales.</span>
		</h1>
		<a class="slide-cta" href="#contacto">Solicitar proyecto</a>
	</div>
</section>

<style>
	/* ─── Hero shell ────────────────────────────────── */
	.hero-carousel {
		position: relative;
		width: 100%;
		height: clamp(440px, 58vw, 680px);
		margin-top: 0;
		margin-bottom: 0;
		overflow: hidden;
		background: #050505;
	}

	.hero-carousel > img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	/* ─── Slide content ─────────────────────────────── */
	.slide-content {
		position: absolute;
		inset: 0;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 1.4rem;
		padding: 0 clamp(1rem, 4vw, 3rem);
		text-align: left;
		max-width: 40%;
	}

	.slide-title {
		margin: 0;
		display: grid;
		gap: 0.55rem;
	}

	.title-headline {
		display: block;
		font-size: clamp(2.8rem, 6vw, 5.5rem);
		font-weight: 800;
		line-height: 1.06;
		color: #fff;
		letter-spacing: -0.01em;
	}

	.title-tagline {
		display: block;
		font-size: clamp(0.95rem, 1.35vw, 1.18rem);
		font-weight: 400;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.84);
	}

	.slide-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 0.85rem 1.6rem;
		border-radius: 4px;
		background: var(--color-primary);
		color: #fff;
		font-weight: 700;
		font-size: 0.95rem;
		box-shadow: 0 12px 30px rgba(243, 88, 44, 0.3);
		transition: transform 0.2s ease, background-color 0.2s ease;
		text-decoration: none;
	}

	.slide-cta:hover,
	.slide-cta:focus-visible {
		transform: translateY(-2px);
		background: #d9461a;
		outline: none;
	}

	/* ─── Responsive ────────────────────────────────── */
	@media (max-width: 960px) {
		.hero-carousel {
			height: clamp(380px, 55vw, 520px);
		}
	}

	@media (max-width: 720px) {
		.hero-carousel {
			height: clamp(320px, 75vw, 460px);
		}
	}
</style>
