---
---

<section class="hero-carousel" id="servicios" aria-label="Servicios POWERLINE">
	<img
		src="/hero/bg2.png"
		alt=""
		loading="eager"
	/>
	<div class="slide-content">
		<h1 class="slide-title" data-reveal data-delay="1">
			<span class="title-headline">Expertos en Instalaciones Electricas en Parral y sus alrededores</span>
			<span class="title-tagline">Resolvemos cualquiera de tus problemas desde proyectos industriales, comerciales y residenciales.</span>
		</h1>
		<a class="slide-cta" href="#contacto" data-reveal style="transition-delay: 0.50s">COTIZA TU PROYECTO</a>
	</div>
</section>

<style>
	/* ─── Hero shell ────────────────────────────────── */
	.hero-carousel {
		position: relative;
		width: 100%;
		height: clamp(440px, 58vw, 680px);
		margin-top: 0;
		margin-bottom: 0;
		overflow: hidden;
		background: #050505;
	}

	.hero-carousel > img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	/* ─── Slide content ─────────────────────────────── */
	.slide-content {
		position: absolute;
		inset: 0;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 2.5rem;
		padding: 0 clamp(2rem, 4vw, 3rem);
		text-align: left;
		max-width: 50%;
	}

	.slide-title {
		margin: 0;
		display: grid;
		gap: 0.55rem;
	}

	.title-headline {
		display: block;
		font-size: clamp(2.8rem, 4.5vw, 5.5rem);
		font-weight: 800;
		line-height: 1.06;
		color: #fff;
		letter-spacing: -0.01em;
	}

	.title-tagline {
		display: block;
		font-size: clamp(0.95rem, 1.35vw, 1.18rem);
		font-weight: 400;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.84);
		text-shadow: 0px 2px 8px rgba(0, 0, 0, 1.0); /* Sombra para mejorar legibilidad sobre fondo oscuro */
	}

	.slide-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		padding: 0.55rem 1.1rem;
		border-radius: 4px;
		background: var(--color-primary);
		color: #fff;
		font-weight: 700;
		font-size: 1rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		box-shadow: 0 12px 30px rgba(243, 88, 44, 0.3);
		transition: background-color 0.2s ease, opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1), transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
		text-decoration: none;
	}

	.slide-cta:hover,
	.slide-cta:focus-visible {
		background: #d9461a;
		outline: none;
	}

	/* ─── Responsive ────────────────────────────────── */
	@media (max-width: 960px) {
		.hero-carousel {
			height: clamp(500px, 58vw, 620px);
		}
	}

	@media (max-width: 720px) {
		.hero-carousel {
			height: clamp(500px, 120vw, 680px);
		}

		.slide-content {
			max-width: 100%;
			align-items: center;
			text-align: center;
			padding: 0 clamp(1.5rem, 6vw, 2.5rem);
			justify-content: center;
		}
	}
</style>
