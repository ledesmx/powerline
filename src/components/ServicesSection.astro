---
const services = [
	{
		number: '01',
		tag: 'Media y Baja Tensión',
		title: 'Ingeniería en Media y Baja Tensión',
		description:
			'Planeación y ejecución experta para energizar proyectos industriales y residenciales.',
		cta: 'Solicitar proyecto',
		serviceValue: 'media-baja-tension',
		image:
			'/Ingenieria-mt-bt.jpeg',
	},
	{
		number: '02',
		tag: 'Gestión Regulatoria',
		title: 'Trámites y Certificaciones',
		description: 'Gestoría ante CFE y dictámenes UVIE bajo la NOM-001-SEDE.',
		cta: 'Iniciar trámite',
		serviceValue: 'tramites-certificaciones',
		image:
			'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=800&q=80',
	},
	{
		number: '03',
		tag: 'Suministro Especializado',
		title: 'Suministro Especializado',
		description:
			'Tienda Fisica Volt. Venta de material eléctrico, transformadores, postes y equipo de control bajo normas CFE.',
		cta: 'Ver catálogo',
		serviceValue: 'suministro-especializado',
		image:
			'/Material.png',
	},
	{
		number: '04',
		tag: 'Logística y Maniobras',
		title: 'Logística y Maniobras de Gruas',
		description:
			'Renta de grúas articuladas y fletes especializados para equipo pesado.',
		cta: 'Solicitar servicio',
		serviceValue: 'logistica-gruas',
		image:
			'/Gruas.jpeg',
	},
	{
		number: '05',
		tag: 'Inspección Técnica',
		title: 'Inspección Técnica y Mantenimiento',
		description: 'Escaneo de redes eléctricas con cámara termográfica por medio de drones.',
		cta: 'Agendar inspección',
		serviceValue: 'inspeccion-mantenimiento',
		image:
			'https://images.unsplash.com/photo-1508614589041-895b88991e3e?auto=format&fit=crop&w=800&q=80',
	},
];
---

<section class="services-section" id="nuestros-servicios" aria-label="Nuestros servicios">
	<div class="services-inner">

		<header class="services-header">
			<div class="header-label">
				<span class="header-line" aria-hidden="true"></span>
				<p class="eyebrow">Nuestros servicios</p>
			</div>
		</header>

		<ul class="services-grid" role="list">
			{services.map((service) => (
				<li class="service-card">
					<img
						src={service.image}
						alt={service.title}
						width="800"
						height="600"
						loading="lazy"
					/>
					<div class="card-overlay" aria-hidden="true"></div>
					<div class="card-content">
						<span class="card-num" aria-hidden="true">{service.number}</span>
						<div class="card-bottom">
							<h3>{service.title}</h3>
							<p class="card-desc">{service.description}</p>
							<div class="card-actions">
							<a class="card-cta" href="#contacto" data-service={service.serviceValue} aria-label={`${service.cta} — ${service.title}`}>
									<span>{service.cta}</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
								</a>
							</div>
						</div>
					</div>
				</li>
			))}
		</ul>

	</div>
</section>

<style>
	section[id] {
  scroll-margin-top: 40px; /* Permite un margen de vista al hacer clic en el navbar*/
	}

	/* ─── Section ───────────────────────────────────── */
	.services-section {
		background: var(--color-surface);
		padding: 2.5rem 0 4rem;
		border-top: 1px solid var(--color-border);
	}

	/* ─── Container ─────────────────────────────────── */
	.services-inner {
		width: var(--content-width);
		margin: 0 auto;
		display: grid;
		gap: 1.5rem;
	}

	/* ─── Header ────────────────────────────────────── */
	.services-header {
		display: grid;
		gap: 0.75rem;
	}

	.header-label {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	@media (max-width: 1024px) {
		.header-label {
			justify-content: center;
		}
	}

	.header-line {
		width: 2.5rem;
		height: 2px;
		background: var(--color-primary);
		flex-shrink: 0;
	}

	.eyebrow {
		margin: 0;
		color: var(--color-primary);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		font-size: clamp(2rem, 3vw, 3.2rem);
		line-height: 1.05;
		color: var(--color-text);
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	/* ─── Grid ──────────────────────────────────────── */
	.services-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		grid-auto-rows: 540px;
		gap: 0.6rem;
	}

	/* ─── Card ──────────────────────────────────────── */
	.service-card {
		position: relative;
		overflow: hidden;
		border-radius: 0.5rem;
		cursor: default;
	}

	.service-card > img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.service-card:hover > img {
		transform: scale(1.06);
	}

	/* ─── Overlay — bottom only ────────────────────── */
	.card-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.82) 0%,
			rgba(0, 0, 0, 0.55) 35%,
			rgba(0, 0, 0, 0) 60%
		);
		transition: background 0.35s ease;
	}

	.service-card:hover .card-overlay {
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.88) 0%,
			rgba(0, 0, 0, 0.6) 38%,
			rgba(0, 0, 0, 0) 62%
		);
	}

	/* ─── Content ───────────────────────────────────── */
	.card-content {
		position: absolute;
		inset: 0;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 1.1rem 1.2rem 1.4rem;
	}

	.card-num {
		position: absolute;
		top: 1.1rem;
		left: 1.2rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.4);
	}

	/* ─── Bottom block ──────────────────────────────── */
	.card-bottom {
		display: grid;
		gap: 0.45rem;
	}

	h3 {
		margin: 0;
		font-size: clamp(1.2rem, 1.6vw, 1.55rem);
		font-weight: 700;
		line-height: 1.2;
		color: #fff;
	}

	.card-desc {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.88);
	}

	/* ─── Actions row ──────────────────────────────── */
	.card-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 0.5rem;
		flex-wrap: wrap;
	}

	/* Primary CTA */
	.card-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.45rem 1rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #fff;
		background: var(--color-primary);
		border-radius: 0.25rem;
		text-decoration: none;
		transition: background-color 0.2s ease, gap 0.2s ease;
		flex-shrink: 0;
	}

	.card-cta:hover {
		background: #d9441c;
		gap: 0.65rem;
	}

	/* Ghost CTA */
	.card-more {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.35);
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
		flex-shrink: 0;
	}

	.card-more:hover {
		color: #fff;
		border-color: #fff;
	}

	/* ─── Responsive ────────────────────────────────── */

	/* Very large: 5 columns, single row */
	@media (min-width: 1400px) {
		.services-grid {
			grid-template-columns: repeat(5, 1fr);
			grid-auto-rows: 540px;
		}
	}

	/* Medium: 6-unit grid → 3 equal top row, 2 equal bottom row */
	@media (max-width: 1399px) {
		.services-grid {
			grid-template-columns: repeat(6, 1fr);
			grid-auto-rows: 380px;
		}

		.service-card:nth-child(1),
		.service-card:nth-child(2),
		.service-card:nth-child(3) { grid-column: span 2; }

		.service-card:nth-child(4),
		.service-card:nth-child(5) { grid-column: span 3; }
	}

	/* Small: single column */
	@media (max-width: 640px) {
		.services-grid {
			grid-template-columns: 1fr;
			grid-auto-rows: 320px;
		}

		.service-card:nth-child(1),
		.service-card:nth-child(2),
		.service-card:nth-child(3),
		.service-card:nth-child(4),
		.service-card:nth-child(5) { grid-column: span 1; }
	}
</style>

<script>
	document.querySelectorAll<HTMLAnchorElement>('.card-cta[data-service]').forEach((link) => {
		link.addEventListener('click', () => {
			const value = link.dataset.service;
			if (!value) return;

			// Store for fallback (page refresh)
			sessionStorage.setItem('preselectServicio', value);

			// Update the select directly — the form is already in the DOM
			const select = document.getElementById('servicio') as HTMLSelectElement | null;
			if (select) select.value = value;
		});
	});
</script>
