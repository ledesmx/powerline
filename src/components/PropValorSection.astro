---
const propsValor = [
  {
    title: "Certificaciones NOM",
    desc: "Cumplimiento total con normativas vigentes oficiales.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path></svg>`
  },
  {
    title: "Experiencia Demostrada",
    desc: "Más de 15 años liderando proyectos de gran escala.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>`
  },
  {
    title: "Garantía en Trabajos",
    desc: "Respaldo total en cada metro de instalación.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"></path><path d="M7 21h10M12 3v18M3 7h18"></path></svg>`
  },
  {
    title: "Atención Personalizada",
    desc: "Asesoría técnica directa para cada necesidad.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`
  },
  {
    title: "Convenio CFE",
    desc: "Aliados estratégicos para agilizar procesos.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m11 17 2 2a1 1 0 1 0 3-3"></path><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"></path></svg>`
  }
];
---
<section class="propuesta-valor">
  <div class="contenedor-grid">
    {propsValor.map((item) => (
      <div class="tarjeta-columna">
        <div class="icono" set:html={item.icon} />
        <h3>{item.title}</h3>
        <p>{item.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .propuesta-valor {
    background-color: #0c0c0c;
    width: 100%;
    display: block;
    margin: 0.5rem 0;
  }

  .contenedor-grid {
    display: grid !important;
    width: 100%;
    /* Mantenemos las 5 columnas */
    grid-template-columns: repeat(5, 1fr);
    background-color: #27272a; 
    gap: 1px; 
    border-top: 1px solid #27272a;
    border-bottom: 1px solid #27272a;
  }

  .tarjeta-columna {
    background-color: #161616;
    padding: 2.5rem 1.5rem; /* Aumentamos un poco el padding para el nuevo tamaño */
    display: flex;
    flex-direction: column;
    /* CENTRADO DE CONTENIDO */
    align-items: center; 
    text-align: center;
    min-height: 220px; /* Ajustamos la altura para que quepa el texto más grande */
    justify-content: center; /* Centra verticalmente el bloque de contenido */
    transition: all 0.3s ease;
  }

  .tarjeta-columna:hover {
    background-color: #1c1c1c;
    box-shadow: inset 0 0 0 1px #ff8800;
  }

  .icono {
    color: #ff8800;
    /* ICONO MÁS GRANDE */
    width: 40px; 
    height: 40px;
    margin-bottom: 1.2rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  h3 {
    color: #ffffff;
    /* TÍTULO MÁS GRANDE */
    font-size: 1.25rem; 
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  p {
    color: #a1a1aa;
    /* TEXTO MÁS GRANDE */
    font-size: 1rem; 
    line-height: 1.5;
    margin: 0;
    max-width: 250px; /* Evita que el texto se estire demasiado hacia los lados */
  }

  /* Responsividad */
  @media (max-width: 1024px) {
    .contenedor-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .contenedor-grid {
      grid-template-columns: 1fr;
    }
    .tarjeta-columna {
      min-height: auto;
      padding: 3rem 1.5rem;
    }
  }
</style>